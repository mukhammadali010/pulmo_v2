# Database
DATABASE_URL=postgresql+asyncpg://pulmoai:pulmoai@localhost:5432/pulmoai_dev

# JWT
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202

# AI provider — `auto` (default), `anthropic`, or `gemini`. With `auto`,
# whichever API key is set wins; if both are set, Gemini wins.
AI_PROVIDER=auto

# Anthropic (Claude). Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Google Gemini — free tier available. Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI mode — set GOOGLE_GENAI_USE_VERTEXAI=true to route Gemini calls
# through your own Google Cloud project (bypasses regional restrictions on the
# AI Studio endpoint). When enabled, GOOGLE_API_KEY is ignored and the SDK
# authenticates via Application Default Credentials — set them up locally with
# `gcloud auth application-default login`. Required prerequisites: a GCP project
# with billing enabled and the Vertex AI API enabled.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Initial admin — provisioned automatically on first startup if no admin exists.
# After the admin is created (or if an admin already exists), these are ignored.
# If an account with INITIAL_ADMIN_EMAIL exists but isn't admin, it is promoted.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=Administrator

# Environment
ENV=development
